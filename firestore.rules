rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Role detection: Direct email whitelist + Firestore DB Admin records
    function isAdmin() {
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email != null && request.auth.token.email.lower() == 'brythema@gmail.com') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // 3. Validation Helpers
    function isValidProfile(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 150 &&
             (!('age' in data) || (data.age is string || data.age is int)) &&
             (!('gender' in data) || (data.gender is string && data.gender.size() <= 20)) &&
             (!('allergies' in data) || (data.allergies is string && data.allergies.size() <= 500)) &&
             (!('chronicConditions' in data) || (data.chronicConditions is string && data.chronicConditions.size() <= 500)) &&
             (!('currentMedications' in data) || (data.currentMedications is string && data.currentMedications.size() <= 500)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 30)) &&
             (!('isConfirmed' in data) || data.isConfirmed is bool) &&
             (!('nextOfKinName' in data) || (data.nextOfKinName is string && data.nextOfKinName.size() <= 150)) &&
             (!('nextOfKinPhone' in data) || (data.nextOfKinPhone is string && data.nextOfKinPhone.size() <= 30)) &&
             (!('nextOfKinRelation' in data) || (data.nextOfKinRelation is string && data.nextOfKinRelation.size() <= 100));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'userId', 'total', 'status', 'timestamp', 'patientName']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId is string && (data.userId == request.auth.uid || isAdmin()) &&
             (data.total is int || data.total is float) && data.total >= 0.0 &&
             data.status in ['Reviewing', 'Dispensed', 'Ready for Pickup', 'Out for Delivery', 'Delivered'] &&
             data.timestamp is string && data.timestamp.size() <= 100 &&
             data.patientName is string && data.patientName.size() <= 150;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'role', 'content', 'timestamp']) &&
             data.id is string && data.id.size() <= 128 &&
             data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() <= 10000 &&
             data.timestamp is string && data.timestamp.size() <= 100;
    }

    function isValidDrug(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'price', 'ingredients', 'requiresPrescription', 'description']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             (data.price is int || data.price is float) && data.price >= 0.0 &&
             data.ingredients is string && data.ingredients.size() <= 500 &&
             data.requiresPrescription is bool &&
             data.description is string && data.description.size() <= 2000;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'message', 'type', 'read', 'timestamp', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 2000 &&
             data.type is string && data.type.size() <= 100 &&
             data.read is bool &&
             data.timestamp is string && data.timestamp.size() <= 100 &&
             data.createdAt is int;
    }

    function isValidSupportRoom(data) {
      return data.keys().hasAll(['id', 'userId', 'userName', 'userEmail', 'topic', 'status', 'createdAt', 'lastMessageText', 'lastMessageAt', 'userUnreadCount', 'adminUnreadCount', 'pharmacyId']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 150 &&
             data.userName is string && data.userName.size() <= 150 &&
             data.userEmail is string && data.userEmail.size() <= 200 &&
             data.topic is string && data.topic.size() <= 200 &&
             data.status in ['open', 'closed'] &&
             (data.createdAt is int || data.createdAt is float) &&
             data.lastMessageText is string && data.lastMessageText.size() <= 10000 &&
             (data.lastMessageAt is int || data.lastMessageAt is float) &&
             (data.userUnreadCount is int || data.userUnreadCount is float) &&
             (data.adminUnreadCount is int || data.adminUnreadCount is float) &&
             data.pharmacyId is string && data.pharmacyId.size() <= 128;
    }

    function isValidSupportMessage(data) {
      return data.keys().hasAll(['id', 'senderId', 'senderName', 'senderRole', 'content', 'createdAt', 'isRead']) &&
             data.id is string && data.id.size() <= 128 &&
             data.senderId is string && data.senderId.size() <= 128 &&
             data.senderName is string && data.senderName.size() <= 150 &&
             data.senderRole in ['patient', 'admin'] &&
             data.content is string && data.content.size() <= 10000 &&
             (data.createdAt is int || data.createdAt is float) &&
             data.isRead is bool &&
             (!('readAt' in data) || (data.readAt is int || data.readAt is float));
    }

    // 4. Secure Path Definition Blocks

    // Notifications
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'admin' || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'admin' || isAdmin());
      allow create: if isSignedIn() && isValidId(notificationId) && isValidNotification(request.resource.data);
      allow update: if isSignedIn() && isValidId(notificationId) && (
        isAdmin() || (
          (resource.data.userId == request.auth.uid) && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
          isValidNotification(request.resource.data)
        )
      );
      allow delete: if isAdmin();
    }

    // Inventory List (Clinical Drugs Catalog)
    match /inventory/{drugId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidDrug(request.resource.data);
      allow delete: if isAdmin();
    }

    // Pharmacy Configurations
    match /pharmacies/{pharmacyId} {
      allow read: if true; // Configurations are publicly readable
      allow write: if isAdmin();
    }

    // Patient Profile Protection
    match /profiles/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && (userId == request.auth.uid || isAdmin()) && isValidProfile(request.resource.data);
      allow update: if isEmailVerified() && (userId == request.auth.uid || isAdmin()) && isValidProfile(request.resource.data);
      allow delete: if isAdmin();
    }

    // Global Orders Registry
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isEmailVerified() && 
                       isValidId(orderId) && 
                       isValidOrder(request.resource.data);
                       
      allow update: if isEmailVerified() && 
                       isValidId(orderId) && 
                       (resource.data.userId == request.auth.uid || isAdmin()) && 
                       request.resource.data.userId == resource.data.userId && 
                       request.resource.data.id == resource.data.id && 
                       (isAdmin() || (
                         resource.data.status != 'Delivered' &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
                       )) &&
                       isValidOrder(request.resource.data);
                       
      allow delete: if isAdmin();
    }

    // Multi-tenant Tenant specific Orders Registry
    match /pharmacies/{pharmacyId}/orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isEmailVerified() && 
                       isValidId(orderId) && 
                       isValidOrder(request.resource.data);
                       
      allow update: if isEmailVerified() && 
                       isValidId(orderId) && 
                       (resource.data.userId == request.auth.uid || isAdmin()) && 
                       request.resource.data.userId == resource.data.userId && 
                       request.resource.data.id == resource.data.id && 
                       (isAdmin() || (
                         resource.data.status != 'Delivered' &&
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
                       )) &&
                       isValidOrder(request.resource.data);
                       
      allow delete: if isAdmin();
    }

    // Global Patient Nurse Chats (Legacy / Top Level)
    match /chats/{userId}/messages/{messageId} {
      allow read, list: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && 
                       (userId == request.auth.uid || isAdmin()) && 
                       isValidId(messageId) && 
                       isValidMessage(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Tenant specific Patient Nurse Chats (Multi-tenant)
    match /pharmacies/{pharmacyId}/chats/{userId}/messages/{messageId} {
      allow read, list: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && 
                       (userId == request.auth.uid || isAdmin()) && 
                       isValidId(messageId) && 
                       isValidMessage(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Support Helpdesk System
    match /support_rooms/{roomId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(roomId) && (request.resource.data.userId == request.auth.uid || isAdmin()) && isValidSupportRoom(request.resource.data);
      allow update: if isSignedIn() && isValidId(roomId) && (resource.data.userId == request.auth.uid || isAdmin()) && isValidSupportRoom(request.resource.data);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, list: if isSignedIn() && (get(/databases/$(database)/documents/support_rooms/$(roomId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && isValidId(messageId) && (request.resource.data.senderId == request.auth.uid || isAdmin()) && isValidSupportMessage(request.resource.data);
        allow update, delete: if isAdmin();
      }
    }

    // Admin List
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && ((userId == request.auth.uid && 'email' in request.auth.token && request.auth.token.email != null && request.auth.token.email.lower() == 'brythema@gmail.com') || isAdmin());
    }

  }
}
